{
  "openapi": "3.1.0",
  "info": {
    "title": "Debate Card Custom GPT API",
    "description": "The GPT should do its own source-finding, claim analysis, tag writing, and card drafting. These actions are only for retrieving the exact passage from a source URL after the GPT has already chosen a source, and for exporting final cards to a verbatim Word document when the user asks.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://75.194.146.17:8000",
      "description": "Current public base URL for the server."
    }
  ],
  "paths": {
    "/api/custom-gpt/extract": {
      "post": {
        "operationId": "extractCardText",
        "summary": "Fetch URLs and extract text between snippets",
        "description": "Use this only after the GPT has already researched and chosen a source URL. Do not use this action to search for sources. The GPT should find the source itself, identify a start snippet and end snippet, then call this action to retrieve the exact passage it wants to quote and cut into a card.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "requests": {
                    "type": "array",
                    "description": "One or more already-selected sources to extract from. The GPT should only send URLs it has already decided are worth cutting.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "url": {
                          "type": "string",
                          "format": "uri",
                          "description": "The chosen source URL. This should already be the source the GPT wants to cut a card from."
                        },
                        "start_snippet": {
                          "type": "string",
                          "description": "A snippet near the beginning of the desired quotation. The GPT should identify this from the source it selected."
                        },
                        "end_snippet": {
                          "type": "string",
                          "description": "A snippet near the end of the desired quotation. The GPT should identify this from the source it selected."
                        },
                        "tag_line": {
                          "type": "string",
                          "description": "Optional tag the GPT intends to use for the card."
                        },
                        "source_title": {
                          "type": "string"
                        },
                        "source_author": {
                          "type": "string"
                        },
                        "source_date": {
                          "type": "string"
                        },
                        "source_publication": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "url"
                      ]
                    }
                  },
                  "domain_blacklist": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Optional domains to block from fetching."
                  }
                },
                "required": [
                  "requests"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Extraction results and card-compatible objects.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "request_id": {
                      "type": "string"
                    },
                    "ok": {
                      "type": "boolean"
                    },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "ok": {
                            "type": "boolean"
                          },
                          "index": {
                            "type": "integer"
                          },
                          "url": {
                            "type": "string"
                          },
                          "resolved_url": {
                            "type": "string"
                          },
                          "title": {
                            "type": "string"
                          },
                          "author": {
                            "type": "string"
                          },
                          "published": {
                            "type": "string"
                          },
                          "publication": {
                            "type": "string"
                          },
                          "extracted_text": {
                            "type": "string"
                          },
                          "error": {
                            "type": "string"
                          },
                          "match": {
                            "type": "object",
                            "properties": {
                              "strategy": {
                                "type": "string"
                              },
                              "start_snippet_found": {
                                "type": "boolean"
                              },
                              "end_snippet_found": {
                                "type": "boolean"
                              },
                              "start_index": {
                                "type": [
                                  "integer",
                                  "null"
                                ]
                              },
                              "end_index": {
                                "type": [
                                  "integer",
                                  "null"
                                ]
                              },
                              "excerpt_length": {
                                "type": "integer"
                              }
                            }
                          },
                          "card": {
                            "type": "object",
                            "description": "Card-compatible object returned when extraction succeeds. The GPT should still decide how to present and format the final card to the user."
                          }
                        }
                      }
                    },
                    "cards": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "meta": {
                      "type": "object",
                      "properties": {
                        "requested_count": {
                          "type": "integer"
                        },
                        "success_count": {
                          "type": "integer"
                        },
                        "failed_count": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/custom-gpt/export/docx": {
      "post": {
        "operationId": "exportCardsDocx",
        "summary": "Generate a verbatim Word document download link",
        "description": "Use this only when the user explicitly wants a Word export. Do not call this during normal card cutting. Accepts formatted cards or structured card objects, generates a .verbatim.docx file, and returns a download URL.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "description": "Title used to name the output file."
                  },
                  "cards": {
                    "type": "array",
                    "description": "Structured card objects or formatted-card objects representing the GPT's final cards.",
                    "items": {
                      "oneOf": [
                        {
                          "type": "object"
                        },
                        {
                          "type": "string"
                        }
                      ]
                    }
                  },
                  "formatted_cards": {
                    "type": "array",
                    "description": "Formatted card strings or objects. Use this when the GPT has already assembled the final debate cards and the user wants them exported.",
                    "items": {
                      "oneOf": [
                        {
                          "type": "object"
                        },
                        {
                          "type": "string"
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The .docx file has been created and can be downloaded from the returned URL.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "request_id": {
                      "type": "string"
                    },
                    "ok": {
                      "type": "boolean"
                    },
                    "filename": {
                      "type": "string"
                    },
                    "download_url": {
                      "type": "string",
                      "format": "uri"
                    },
                    "download_path": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
