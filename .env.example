PORT=8000

# Local model via Ollama. This is the preferred no-API-cost path.
# Set OLLAMA_BASE_URL to a local daemon or a remote Ollama server.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT=120

# Optional: pin the provider when you want auto-detection to prefer one path.
# Supported values include ollama, bedrock, openai_compat, openai, and fallback.
# LOCAL_MODEL_PROVIDER=ollama

# Generic OpenAI-compatible endpoint for hosted inference servers.
# Example use cases: remote lab machines, vendor-compatible chat-completions APIs,
# or NVIDIA-style hosted endpoints when you have a compatible URL and key.
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_PATH=/chat/completions

# Example NVIDIA-compatible settings.
# OPENAI_COMPAT_BASE_URL=https://integrate.api.nvidia.com/v1
# OPENAI_COMPAT_MODEL=tiiuae/falcon3-7b-instruct
# OPENAI_COMPAT_API_KEY=nvapi-your-key

# Native Amazon Bedrock provider for Meta Llama 4 Scout 17B Instruct.
# This path uses the Bedrock Converse API rather than OpenAI-compatible chat completions.
# For Llama 4 Scout, prefer the inference profile ID instead of the raw model ID.
BEDROCK_MODEL=us.meta.llama4-scout-17b-instruct-v1:0
BEDROCK_INFERENCE_PROFILE=
BEDROCK_REGION=us-west-2
BEDROCK_API_KEY=
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_BASE_URL=

# Research/source discovery. These tune search scraping and article extraction.
# The UI defaults to semantic search, with a literal-search toggle in the browser.
# Query refinement uses the configured AI provider when available and falls back to deterministic heuristics when it is not.
# Source discovery builds a mixed candidate pool: academic/paper-like sources, think-tank reports, and general web backfill.
SEARCH_ENGINE=duckduckgo
SEARCH_RESULTS=50
SOURCE_RETRY_LIMIT=10
SOURCE_SELECTION_SNIPPET_CHARS=220
MAX_QUEUE_TAGS=25
SEARCH_TIMEOUT=20
FETCH_TIMEOUT=20
FETCH_MAX_BYTES=1500000
MODEL_INPUT_MAX_CHARS=24000
MODEL_OUTPUT_TOKENS=3500
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
# Optional domain blacklist, applied to research and source selection.
BLOCKED_DOMAINS=

# Optional OpenAI fallback. API billing is separate from ChatGPT subscriptions.
# Leave OPENAI_API_KEY empty if you want no API billing at all.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_BASE_URL=https://api.openai.com/v1/responses

# Experimental ChatGPT subscription bridge.
# This is NOT an official OpenAI API path. It is only for a separate bridge service
# you run yourself, and it should be treated as brittle/unsupported.
CHATGPT_BRIDGE_BASE_URL=
CHATGPT_BRIDGE_MODEL=
CHATGPT_BRIDGE_API_KEY=
CHATGPT_BRIDGE_PATH=/chat/completions
CHATGPT_BRIDGE_TIMEOUT=120
